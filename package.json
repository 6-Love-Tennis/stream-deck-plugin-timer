{
  "name": "next-meeting-countdown",
  "version": "0.2.0",
  "description": "Stream Deck plugin that counts down to your next macOS Calendar meeting.",
  "type": "module",
  "author": "Greg Henkhaus",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w --watch.onEnd=\"streamdeck restart app.6love.next-meeting\""
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.1.0"
  },
  "devDependencies": {
    "@elgato/cli": "^1.7.4",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.0.0",
    "rollup": "^4.22.0",
    "tslib": "^2.7.0",
    "typescript": "^5.6.0"
  }
}
