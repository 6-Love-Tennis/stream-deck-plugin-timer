{
	"Name": "Next Meeting Countdown",
	"Version": "0.2.1.0",
	"Author": "6-Love",
	"Actions": [
		{
			"Name": "Next Meeting",
			"UUID": "app.6love.next-meeting.countdown",
			"Icon": "imgs/actions/countdown/icon",
			"Tooltip": "Counts down to the start of your next macOS Calendar meeting.",
			"PropertyInspectorPath": "ui/countdown.html",
			"Controllers": [
				"Keypad",
				"Encoder"
			],
			"States": [
				{
					"Image": "imgs/actions/countdown/key",
					"TitleAlignment": "middle"
				}
			],
			"Encoder": {
				"layout": "layouts/dial.json",
				"Icon": "imgs/actions/countdown/icon",
				"TriggerDescription": {
					"Push": "Join meeting",
					"Touch": "Join meeting"
				}
			}
		},
		{
			"Name": "Current Meeting",
			"UUID": "app.6love.next-meeting.current",
			"Icon": "imgs/actions/countdown/icon",
			"Tooltip": "Shows the time left in the meeting you're currently in.",
			"PropertyInspectorPath": "ui/countdown.html",
			"Controllers": [
				"Keypad",
				"Encoder"
			],
			"States": [
				{
					"Image": "imgs/actions/countdown/key",
					"TitleAlignment": "middle"
				}
			],
			"Encoder": {
				"layout": "layouts/dial.json",
				"Icon": "imgs/actions/countdown/icon",
				"TriggerDescription": {
					"Push": "Join meeting",
					"Touch": "Join meeting"
				}
			}
		}
	],
	"Category": "Next Meeting Countdown",
	"CategoryIcon": "imgs/plugin/category-icon",
	"CodePath": "bin/plugin.js",
	"Description": "Shows a live countdown to your next meeting from macOS Calendar.",
	"Icon": "imgs/plugin/marketplace",
	"SDKVersion": 3,
	"Software": {
		"MinimumVersion": "7.1"
	},
	"OS": [
		{
			"Platform": "mac",
			"MinimumVersion": "12"
		}
	],
	"Nodejs": {
		"Version": "24",
		"Debug": "enabled"
	},
	"UUID": "app.6love.next-meeting"
}